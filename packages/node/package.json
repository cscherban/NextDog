{
  "name": "@nextdog/node",
  "version": "0.1.0",
  "description": "Shared Node.js instrumentation for NextDog — OTel exporter, sidecar, console capture",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./exporter": "./dist/exporter.js",
    "./sidecar": "./dist/sidecar.js",
    "./console-patch": "./dist/console-patch.js",
    "./request-capture": "./dist/request-capture.js",
    "./request-context": "./dist/request-context.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nextdog/core": "workspace:*",
    "@opentelemetry/api": "^1",
    "@opentelemetry/sdk-trace-node": "^1",
    "@opentelemetry/resources": "^1",
    "@opentelemetry/semantic-conventions": "^1"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@opentelemetry/core": "^2",
    "vitest": "^3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cscherban/NextDog"
  },
  "keywords": ["node", "observability", "tracing", "opentelemetry", "devtools", "instrumentation"]
}
