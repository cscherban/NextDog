{
  // Type-check-only config for @nextdog/ui.
  //
  // The package is bundled by Vite, not emitted by tsc, so production builds
  // never run a type-checker — type debt could accumulate silently. `pnpm
  // typecheck` runs `tsc --noEmit` against this config to give the package a
  // real gate.
  //
  // Two overrides vs the build tsconfig:
  //  - `moduleResolution: "Bundler"` matches how Vite resolves modules (and how
  //    the code is actually authored), so bare directory imports and the
  //    `styled-system` alias resolve the same way they do at build time.
  //  - the `styled-system/*` path maps the Panda CSS codegen output (which lives
  //    at the package root, is gitignored, and is regenerated by `panda
  //    codegen` on install) so tsc finds it instead of reporting bogus
  //    "cannot find module 'styled-system/css'" errors. The codegen dir itself
  //    is never compiled or emitted.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "styled-system/*": ["./styled-system/*"]
    }
  },
  "include": ["src"]
}
