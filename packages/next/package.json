{
  "name": "@nextdog/next",
  "version": "0.1.0",
  "description": "Next.js plugin for NextDog — zero-config dev observability",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./register": "./dist/register.js",
    "./client": "./dist/client.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nextdog/core": "workspace:*",
    "@opentelemetry/api": "^1",
    "@opentelemetry/sdk-trace-node": "^1",
    "@opentelemetry/resources": "^1",
    "@opentelemetry/semantic-conventions": "^1"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": { "optional": false }
  },
  "devDependencies": {
    "@types/node": "^25",
    "@opentelemetry/core": "^2",
    "vitest": "^3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cscherban/NextDog"
  },
  "keywords": ["nextjs", "observability", "tracing", "opentelemetry", "devtools", "instrumentation"]
}
