{
  "name": "@nextdog/core",
  "version": "0.1.0",
  "description": "Zero-config dev observability sidecar for Next.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nextdog": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nextdog/ui": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cscherban/NextDog"
  },
  "keywords": ["nextjs", "observability", "tracing", "opentelemetry", "devtools"]
}
